{
  "name": "{{ projectName }}",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:codegen": "playwright codegen"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tanstack/react-router": "^1.45.0",
    "@tanstack/react-query": "^5.51.0",
    "i18next": "^23.12.0",
    "react-i18next": "^15.0.0",
{% if authProvider == "clerk" %}
    "@clerk/clerk-react": "^5.2.0"
{% else %}
    "oidc-client-ts": "^3.0.1",
    "react-oidc-context": "^3.1.0"
{% endif %}
  },
  "devDependencies": {
    "@module-federation/vite": "^1.14.0",
    "@module-federation/enhanced": "^0.8.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "~5.5.0",
    "vite": "^5.4.0",
{% if features.tailwind %}
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
{% endif %}
    "@playwright/test": "^1.45.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
